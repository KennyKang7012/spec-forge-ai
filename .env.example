# SpecForge AI - 環境變數設定範例
# 請複製此檔案為 .env 並填入實際值
# ================================

# === JWT 認證 ===
JWT_SECRET_KEY=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === SQLite 資料庫 (必須包含 +aiosqlite 以支援異步) ===
DATABASE_URL=sqlite+aiosqlite:///./data/specforge.db

# === LLM 供應商設定（預設使用 Ollama） ===
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:31b-cloud
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI（需要時取消註解）
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4

# Google Gemini（需要時取消註解）
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODEL=gemini-pro

# OpenRouter（需要時取消註解）
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=your-model-choice

# Nvidia（需要時取消註解）
# LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=your-nvidia-key
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=your-model-choice

# 公司內部 / 自訂 LLM Server（需要時取消註解）
# 支援任何 OpenAI 兼容 API 的服務（如 vLLM, LocalAI, LiteLLM, FastChat 等）
# LLM_PROVIDER=custom                                    # 供應商類型：固定填 custom
# CUSTOM_LLM_NAME=Internal-LLM                           # 顯示名稱：在前端設定頁面顯示的名稱
# CUSTOM_LLM_BASE_URL=https://llm.your-company.com/v1    # API 網址：內部 LLM Server 的 OpenAI 兼容端點
# CUSTOM_LLM_API_KEY=your-internal-key                   # API 金鑰：內部服務的認證金鑰（若無需認證可留空）
# CUSTOM_LLM_MODEL=your-internal-model                   # 模型名稱：要使用的模型 ID

# === 應用設定 ===
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
DEFAULT_LANGUAGE=zh-TW
